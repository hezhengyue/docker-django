# ===================== 🔐 基础安全 =====================
# Django 根密钥：用于 Session/CSRF/密码哈希等所有加密操作。生产必须替换！
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=Z2tDWijnp7UYE57EL2K3Crl00mEkSW-KHqKhbJmrMjM=
# 调试模式：true=开发(详细报错+热重载)，false=生产(关闭+隐藏栈信息)
DEBUG=true

# ===================== 🌐 访问与安全 =====================
# 允许访问的域名/IP白名单：逗号分隔，不带协议/端口。开发留 localhost，生产填实际域名
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
# CSRF 信任源：必须带 http/https 协议。前后端分离或跨域表单提交必配
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
# 信任代理 IP：配合 RealIPMiddleware 获取客户端真实 IP。开发留本地环回，生产填 Nginx/SLB 内网 IP
TRUSTED_PROXIES=127.0.0.1,::1

# ===================== 🔑 会话配置 =====================
# 会话有效期(秒)：用户无操作自动退出时间。后台建议 1200(20m)，C端可 86400(1天)
SESSION_COOKIE_AGE=1200
# 安全 Cookie 传输：true=仅 HTTPS 发送。开发 false，生产必须 true(否则登录失效)
CSRF_COOKIE_SECURE=false
SESSION_COOKIE_SECURE=false

# ===================== 🗄️ 数据库 =====================
# PostgreSQL 主机名：容器内用 'db'，本地开发可用 'localhost'
POSTGRES_HOST=localhost
# PostgreSQL 用户名：容器初始化创建。生产建议专用应用账号
POSTGRES_USER=postgres
# PostgreSQL 密码：⚠️ 生产必须强密码。仅改此项，DATABASE_URL 会自动拼接
POSTGRES_PASSWORD=Postgres1234
# PostgreSQL 数据库名：首次启动自动创建。建议按环境区分 (如 db_prod)
POSTGRES_DB=db
# PostgreSQL 端口：容器内部通信固定 5432，仅用于拼接 URL 与健康检查
POSTGRES_PORT=5432
# ===================== 🚀 缓存与异步任务 =====================
# Redis 主机名：容器内用 'redis'，本地开发可用 'localhost'
REDIS_HOST=localhost
# Redis 端口：默认 6379，一般无需修改
REDIS_PORT=6379
# Redis 密码：开发留空，生产建议设置并加密
REDIS_PASSWORD=Redis1234
# 默认缓存，Redis 数据库分库：0-15，不同用途建议分库隔离
REDIS_DB=0
# Celery 消息队列分库：仅填分库号 (0-15)，完整 URL 由 REDIS_* 自动拼接
CELERY_BROKER_DB=1
# Celery 结果后端分库：仅填分库号 (0-15)，完整 URL 由 REDIS_* 自动拼接
CELERY_RESULT_BACKEND_DB=2
# 单任务最大执行时间 (秒)：超时强制终止防死锁。短任务 60，长报表 600~1800
CELERY_TASK_TIME_LIMIT=300

# ===================== 📝 日志配置 =====================
# 控制台日志级别：DEBUG(开发全量)/INFO(生产推荐)/WARNING(仅异常)
LOG_LEVEL=DEBUG
# 文件日志级别：通常比控制台高一级，减少磁盘写入压力
LOG_FILE_LEVEL=INFO
# 日志保留天数：按天轮转，超期自动清理。合规要求常需 90 天，测试环境可 3~7 天
LOG_RETENTION_DAYS=30

# ===================== 📁 文件上传 =====================
# 请求体最大内存缓冲：超过则落盘。必须 ≤ Nginx client_max_body_size
DATA_UPLOAD_MAX_MEMORY_SIZE=50M
# 单文件最大内存缓冲：同上，针对单个文件。按业务调整(头像 2M/视频 500M)
FILE_UPLOAD_MAX_MEMORY_SIZE=50M

# ===================== 🌏 国际化 =====================
# 默认语言：zh-hans(简体中文)/en-us(英文)。影响后台与模板翻译
LANGUAGE_CODE=zh-hans
# 默认时区：Asia/Shanghai(中国)/UTC(国际)。影响 now() 与数据库存储
TIME_ZONE=Asia/Shanghai
# 启用时区支持：true=存 UTC 显本地(推荐)/false=存本地(易混乱)
USE_TZ=true


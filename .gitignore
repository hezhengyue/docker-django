# .gitignore

# 🔐 环境配置（敏感信息）
.env
.env.local
!.env.example

# 🔐 密钥/证书
*.key
*.pem
*.crt

# 🐍 Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv

# 🗄️ 数据库
db.sqlite3
db.sqlite3-journal

# 📁 静态/媒体文件（开发生成）
staticfiles/
media/

# 📝 日志
*.log
logs/

# 💻 IDE
.idea/
.vscode/
*.swp
*.swo

# 🐳 Docker
.docker/
docker-compose.override.yml